---
import { Image } from "astro:assets";
import profilePic from "../assets/hero-pic.jpg";
---

<section
    id="hero"
    class="max-w-7xl mx-auto px-6 py-16 md:py-0 grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16 items-center min-h-[100dvh]"
>
    <div
        class="space-y-6 lg:space-y-8 text-center md:text-left flex flex-col items-center md:items-start mt-10 md:mt-0"
    >
        <h1
            class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-gray-900 leading-[1.1]"
        >
            Hi, I'm <span class="text-blue-600">Kim L. Raya </span>
        </h1>

        <p class="text-xl sm:text-2xl font-medium text-gray-700">
            Data Analyst & Visualization Expert
        </p>

        <p class="text-base sm:text-lg text-gray-600 max-w-xl leading-relaxed">
            I transform complex data into actionable insights. Specializing in
            data visualization, statistical analysis, and building automated
            reporting solutions to drive business decisions.
        </p>

        <div class="flex flex-wrap gap-4 pt-4 justify-center md:justify-start">
            <a
                href="#contact"
                class="px-6 sm:px-8 py-3.5 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition shadow-md w-full sm:w-auto text-center"
            >
                Get in Touch
            </a>
            <a
                href="#projects"
                class="px-6 sm:px-8 py-3.5 text-blue-700 font-semibold rounded-lg hover:bg-blue-50 transition border border-gray-200 shadow-sm w-full sm:w-auto text-center"
            >
                View Projects
            </a>
        </div>

        <div
            class="flex items-center gap-6 pt-6 text-gray-500 justify-center md:justify-start"
        >
            <a
                href="https://github.com/kimraya"
                target="_blank"
                aria-label="GitHub"
                class="hover:text-gray-900 transition"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6 sm:w-7 sm:h-7"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    ><path
                        d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                    ></path></svg
                >
            </a>
            <a
                href="https://www.linkedin.com/in/kim-raya-10462022a/"
                target="_blank"
                aria-label="LinkedIn"
                class="hover:text-gray-900 transition"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6 sm:w-7 sm:h-7"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    ><path
                        d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                    ></path></svg
                >
            </a>
            <a
                href="mailto:kimraya1017@gmail.com"
                aria-label="Email"
                class="hover:text-gray-900 transition"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="w-6 h-6 sm:w-7 sm:h-7"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    ><path
                        d="M0 3v18h24v-18h-24zm21.518 2l-9.518 7.713-9.518-7.713h19.036zm-19.518 14v-11.817l10 8.104 10-8.104v11.817h-20z"
                    ></path></svg
                >
            </a>
        </div>
    </div>

    <div
        class="flex justify-center w-full max-w-sm mx-auto md:max-w-none md:justify-end lg:pl-10"
    >
        <div
            class="relative animate-blob overflow-hidden shadow-2xl bg-white border border-gray-100 group w-full"
        >
            <Image
                src={profilePic}
                alt="Kim L. Raya - Data Analyst"
                class="w-full h-auto aspect-square object-cover"
                format="webp"
                quality="high"
            />
            <div class="absolute inset-0 bg-blue-600/0 transition-colors"></div>
        </div>
    </div>
</section>
