---
// Import the Image component 
import { Image } from "astro:assets";

// Import the actual picture of each projects 
import project1 from "../assets/project1.jpg";
import project2 from "../assets/project2.jpg";
import project3 from "../assets/project3.jpg";     


// src/components/Projects.astro

// A senior dev stores data in an array or JSON file, then maps over it!
const projectsData = [
    {
        title: "Public Health Dashboard: Leptospirosis in Davao City",
        description:
            "An interactive public health dashboard visualizing a decade of Leptospirosis trends, geographical hotspots, and case severity in Davao City",
        tags: ["Python", "Pandas", "Excel", "Looker Studio"],
        codeLink: "#",
        demoLink: "https://lookerstudio.google.com/reporting/06a7711b-6ae1-4f70-828e-6e6072e5c839",
        image: project1,
    },
    {
        title: "National Disease Surveillance Dashboard",
        description:
            "A dynamic health dashboard tracking national epidemiological trends through demographic filtering, time-series curves, and key mortality metrics",
        tags: ["Python", "Pandas", "Excel", "Looker Studio"],
        codeLink: "#",
        demoLink: "https://lookerstudio.google.com/reporting/b15dd8e3-bf0e-406a-a49f-19aa9fc35b43",
        image: project2,
    },
    {
        title: "E-Commerce Sales Performance Analysis",
        description:
            "An interactive Looker Studio dashboard tracking global e-commerce revenue, average order value, and product category trends",
        tags: ["Excel", "Power Query" , "Google Analytics", "Looker Studio"],
        codeLink: "#",
        demoLink: "https://datastudio.google.com/reporting/ed9e1421-7207-41cd-a057-c4c1f47b1556",
        image: project3,
    },
];
---

<section id="projects" class="pt-10 pb-40 min-h-screen flex flex-col justify-center bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16">
            <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl">
                Featured Projects
            </h2>
            <p class="mt-4 text-lg text-gray-600">
                Here are some of my recent works
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {
                projectsData.map((project) => (
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-xl transition-shadow duration-300 flex flex-col">
                        <div class="h-48 overflow-hidden">
                            <Image
                                src={project.image}
                                alt={project.title}
                                class="w-full h-full object-cover"
                            />
                        </div>

                        <div class="p-6 flex flex-col grow">
                            <h3 class="text-xl font-bold text-gray-900 mb-2">
                                {project.title}
                            </h3>
                            <p class="text-gray-600 text-sm mb-6 grow">
                                {project.description}
                            </p>

                            <div class="flex flex-wrap gap-2 mb-6">
                                {project.tags.map((tag) => (
                                    <span class="px-3 py-1 bg-blue-50 text-blue-600 rounded-full text-xs font-semibold">
                                        {tag}
                                    </span>
                                ))}
                            </div>

                            <div class="flex items-center gap-4 text-sm font-medium text-gray-700 mt-auto">
                                <a
                                    href={project.codeLink}
                                    target="_blank"
                                    class="flex items-center gap-1.5 hover:text-blue-600 transition-colors"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="w-5 h-5"
                                        viewBox="0 0 24 24"
                                        fill="currentColor"
                                    >
                                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                                    </svg>
                                    Code
                                </a>
                                <a
                                    href={project.demoLink}
                                    target="_blank"
                                    class="flex items-center gap-1.5 hover:text-blue-600 transition-colors"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        class="w-5 h-5"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                    >
                                        <>
                                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                            <polyline points="15 3 21 3 21 9" />
                                            <line
                                                x1="10"
                                                y1="14"
                                                x2="21"
                                                y2="3"
                                            />
                                        </>
                                    </svg>
                                    Demo
                                </a>
                            </div>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
