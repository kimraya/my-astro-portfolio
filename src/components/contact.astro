---
// src/components/Contact.astro

// 1. Separate the data for easy updating
const contactInfo = [
    {
        title: "Email",
        value: "kimraya1017@gmail.com", // Replace with your actual email
        link: "mailto:kim.raya@example.com",
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
    },
    {
        title: "Phone",
        value: "+63 (950) 646-5623", // Replace with your actual phone
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
    },
    {
        title: "Location",
        value: "Davao Region, Philippines",
        link: "#", // Leave as # or link to a Google Maps pin
        icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
    },
];
---

<section
    id="contact"
    class="py-20 bg-gray-50 min-h-screen flex flex-col justify-center"
>
    <div class="max-w-6xl mx-auto px-6 lg:px-8 w-full">
        <div class="text-center mb-16">
            <h2 class="text-3xl sm:text-4xl font-bold text-gray-900">
                Get In Touch
            </h2>
            <p class="mt-4 text-lg text-gray-600">
                Let's work together on your next project
            </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
            <div class="flex flex-col justify-center">
                <h3 class="text-2xl font-bold text-gray-900 mb-8">
                    Contact Information
                </h3>
                <div class="space-y-8">
                    {
                        contactInfo.map((info) => (
                            <a
                                href={info.link}
                                class="flex items-start gap-5 group"
                            >
                                <div
                                    class="w-12 h-12 rounded-xl bg-blue-100 text-blue-600 flex items-center justify-center shrink-0 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300"
                                    set:html={info.icon}
                                />

                                <div>
                                    <h4 class="text-sm font-semibold text-gray-900 mb-1">
                                        {info.title}
                                    </h4>
                                    <p class="text-gray-600 group-hover:text-blue-600 transition-colors duration-300">
                                        {info.value}
                                    </p>
                                </div>
                            </a>
                        ))
                    }
                </div>
            </div>

            <form action="#" method="POST" class="flex flex-col space-y-6">
                <div>
                    <label
                        for="name"
                        class="block text-sm font-medium text-gray-900 mb-2"
                        >Name</label
                    >
                    <input
                        type="text"
                        id="name"
                        name="name"
                        required
                        class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 outline-none transition-all"
                        placeholder="John Doe"
                    />
                </div>

                <div>
                    <label
                        for="email"
                        class="block text-sm font-medium text-gray-900 mb-2"
                        >Email</label
                    >
                    <input
                        type="email"
                        id="email"
                        name="email"
                        required
                        class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 outline-none transition-all"
                        placeholder="john@example.com"
                    />
                </div>

                <div>
                    <label
                        for="message"
                        class="block text-sm font-medium text-gray-900 mb-2"
                        >Message</label
                    >
                    <textarea
                        id="message"
                        name="message"
                        rows="5"
                        required
                        class="w-full px-4 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 focus:ring-2 focus:ring-blue-600 focus:border-blue-600 outline-none transition-all resize-y"
                        placeholder="How can I help you?"></textarea>
                </div>

                <button
                    type="submit"
                    class="w-full px-8 py-4 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors shadow-md focus:ring-4 focus:ring-blue-200 outline-none"
                >
                    Send Message
                </button>
            </form>
        </div>
    </div>
</section>
